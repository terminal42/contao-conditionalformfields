{
    "name": "terminal42/contao-conditionalformfields",
    "description": "conditionalformfields extension for Contao Open Source CMS; Display form fields based on conditionis!",
    "keywords": ["contao", "form", "conditions", "fields"],
    "type": "contao-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "terminal42 gmbh",
            "homepage": "https://www.terminal42.ch"
        }
    ],
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/terminal42"
        },
        {
            "type": "other",
            "url": "https://ko-fi.com/terminal42"
        }
    ],
    "support": {
        "issues": "https://github.com/terminal42/contao-conditionalformfields/issues",
        "source": "https://github.com/terminal42/contao-conditionalformfields"
    },
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.7",
        "doctrine/dbal": "^3.6 || ^4.3",
        "symfony/asset": "^7.4",
        "symfony/config": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/expression-language": "^7.4",
        "symfony/http-foundation": "^7.4",
        "symfony/http-kernel": "^7.4",
        "symfony/translation-contracts": "^3.0"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.0",
        "terminal42/contao-build-tools": "dev-main",
        "terminal42/contao-mp_forms": "^4.4 || ^5.0"
    },
    "conflict": {
        "contao/manager-plugin": "<2.0 || >=3.0",
        "terminal42/contao-mp_forms": "<4.4 || >= 6.0"
    },
    "autoload": {
        "psr-4": {
            "Terminal42\\ConditionalformfieldsBundle\\": "src/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Terminal42\\ConditionalformfieldsBundle\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": false,
            "php-http/discovery": false,
            "contao/manager-plugin": false,
            "terminal42/contao-build-tools": true
        }
    }
}
